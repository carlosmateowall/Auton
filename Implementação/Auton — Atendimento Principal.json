    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\nconst body = raw.body || raw;\n\nif (body.payload?.fromMe === true) return [];\nif (body.event && body.event !== 'message') return [];\n\nconst phone = (body.payload?.from || '').replace('@c.us', '').replace('+', '').replace(/\\D/g, '');\nconst text  = (body.payload?.body || '').trim();\n\nif (!phone || !text) return [];\n\nreturn [{ json: { phone, text, session: body.session || 'default', raw: body.payload } }];"
      },
