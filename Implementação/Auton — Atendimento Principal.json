    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Estado atual da conversa (fallback: idle)\nlet newState   = item.conv?.state || 'idle';\nlet newContext = item.ctx || {};\n\nif (item.action === 'update_state' && item.data?.state) {\n  newState   = item.data.state;\n  newContext = typeof item.data.context === 'object' ? item.data.context : {};\n} else if (item.action === 'book_appointment') {\n  // Agendamento concluído → resetar conversa\n  newState   = 'idle';\n  newContext = {};\n} else if (item.action === 'cancel_appointment') {\n  newState   = 'idle';\n  newContext = {};\n}\n// reply_only → mantém estado atual\n\nconst { randomUUID } = require('crypto');\nconst convId = item.conv?.id || randomUUID();\n\nreturn [{ json: { ...item, convId, newState, newContext } }];"
      },
