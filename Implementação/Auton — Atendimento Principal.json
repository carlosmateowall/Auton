      "id": "70c9cc37-ed4b-434e-b5ac-bf0fb23d683e",
      "name": "Webhook WAHA",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-1456, 160],
      "webhookId": "auton-waha-incoming"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// O N8N encapsula o POST body em raw.body\nconst body = raw.body || raw;\n\n// Ignorar mensagens enviadas pelo próprio bot\nif (body.payload?.fromMe === true) {\n  return [];\n}\n\n// Ignorar eventos que não sejam mensagem\nif (body.event && body.event !== 'message') {\n  return [];\n}\n\nconst phone = (body.payload?.from || '').replace('@c.us', '').replace('+', '').replace(/\\D/g, '');\nconst text  = (body.payload?.body || '').trim();\n\nif (!phone || !text) return [];\n\nreturn [{\n  json: {\n    phone,\n    text,\n    session: body.session || 'default',\n    raw: body.payload\n  }\n}];"
      },
      "id": "44a8b355-4a07-4b20-8754-d37b186efdab",
      "name": "Parsear mensagem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1232, 160]
    },
