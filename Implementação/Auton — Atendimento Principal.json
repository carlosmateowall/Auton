    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\n\nif (body.payload?.fromMe === true) return [];\nif (body.event && body.event !== 'message') return [];\n\nconst from  = body.payload?.from || '';\nconst phone = from.replace(/@.*$/, '');\nconst text  = (body.payload?.body || '').trim();\n\nif (!from || !text) return [];\n\nreturn [{ json: {\n  phone,\n  chatId:  from,\n  text,\n  session: body.session || 'default',\n  raw:     body.payload\n} }];"
      },
