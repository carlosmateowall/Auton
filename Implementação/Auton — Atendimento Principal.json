      "id": "25768fa6-29b2-4dcd-a1bf-3bf647e86ec0",
      "name": "Buscar slots",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [-1024, 304],
      "credentials": {
        "supabaseApi": {
          "id": "ArEp44L1ngousPz7",
          "name": "Supabase account"
