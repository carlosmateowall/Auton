      "id": "25768fa6-29b2-4dcd-a1bf-3bf647e86ec0",
      "name": "Buscar slots",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [-1024, 304],
      "credentials": {
        "supabaseApi": {
          "id": "z0zNqcQtLcx0Z9TV",
          "name": "Supabase account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const parsed   = $('Parsear mensagem').item.json;\nconst convAll  = $('Buscar conversa').all();\nconst patAll   = $('Buscar paciente').all();\nconst slotAll  = $('Buscar slots').all();\n\nconst conv    = convAll[0]?.json  || { state: 'idle', context: '{}', clinic_id: null };\nconst patient = patAll[0]?.json   || null;\nconst slots   = slotAll.map(s => s.json);\n\n// Parsear context se vier como string\nlet ctx = {};\ntry { ctx = typeof conv.context === 'string' ? JSON.parse(conv.context) : (conv.context || {}); } catch(e) {}\n\n// Montar lista de slots formatada\nconst dias = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];\nconst slotsList = slots.length\n  ? slots.map((s, i) => {\n      const d = new Date(s.date + 'T00:00:00-03:00');\n      return `${i+1}. ${dias[d.getDay()]} ${d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})} às ${s.time.slice(0,5)}`;\n    }).join('\\n')\n  : 'Nenhum horário disponível no momento.';\n\nconst systemPrompt = `Você é a assistente virtual da Clínica Piloto Auton, especializada em agendamentos.\n\nSERVIÇOS DISPONÍVEIS:\n- Consulta clínica\n- Retorno\n- Exame laboratorial\n\nHORÁRIOS DISPONÍVEIS (próximos ${slots.length} slots livres):\n${slotsList}\n\nDADOS DO PACIENTE:\n- Nome: ${patient?.name || 'Novo paciente'}\n- Última visita: ${patient?.last_visit || 'Nunca'}\n\nESTADO DA CONVERSA: ${conv.state || 'idle'}\nCONTEXTO: ${JSON.stringify(ctx)}\n\nINSTRUÇÕES:\n1. Responda SEMPRE com JSON válido neste formato exato (sem texto fora do JSON):\n   {\"action\": \"...\", \"message\": \"...\", \"data\": {}}\n\n2. ACTIONS:\n   - reply_only         → só responder\n   - update_state       → mudar estado (data obrigatório: {state, context})\n   - book_appointment   → agendar (data obrigatório: {slot_index: 0-${slots.length-1}, service: \"...\"})\n   - cancel_appointment → cancelar agendamento ativo\n\n3. FLUXO:\n   idle → identifying (pedir nome se novo) → scheduling (mostrar slots) → book_appointment\n\n4. REGRAS:\n   - Use APENAS os horários listados acima\n   - Se não houver horários: informe e peça para tentar amanhã\n   - Fora do escopo: \"Para isso fale com a recepção 😊\"\n   - Tom: informal, simpático, objetivo, português BR\n   - Use emojis com moderação (✅ 📅 ⏰ 😊)\n   - Ao confirmar agendamento: inclua nome, serviço, data e hora`;\n\nreturn [{\n  json: {\n    systemPrompt,\n    userMessage: parsed.text,\n    phone: parsed.phone,\n    session: parsed.session,\n    slots,\n    patient,\n    conv,\n    ctx,\n    clinicId: slots[0]?.clinic_id || conv.clinic_id || null\n  }\n}];"
      },
      "id": "248bc2d7-ffc6-4a8c-8847-72cf5b10a3a0",
      "name": "Montar contexto Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-800, 160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-6\",\n  \"max_tokens\": 512,\n  \"system\": {{ JSON.stringify($json.systemPrompt) }},\n  \"messages\": [{ \"role\": \"user\", \"content\": {{ JSON.stringify($json.userMessage) }} }]\n}",
        "options": {}
      },
      "id": "ee53059a-5018-4fd8-93c6-a96ac48a9389",
      "name": "Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [-576, 160],
      "credentials": {
        "httpHeaderAuth": {
          "id": "whtcMiXQaQqdpSKb",
          "name": "x-api-key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json?.content?.[0]?.text || '{}';\nconst ctx = $('Montar contexto Claude').item.json;\n\nlet resp;\ntry {\n  const clean = rawText.replace(/```json\\s*/g,'').replace(/```\\s*/g,'').trim();\n  resp = JSON.parse(clean);\n} catch(e) {\n  resp = { action: 'reply_only', message: 'Desculpe, tive um probleminha aqui. Pode repetir? 😅', data: {} };\n}\n\nreturn [{\n  json: {\n    action:   resp.action  || 'reply_only',\n    message:  resp.message || '',\n    data:     resp.data    || {},\n    phone:    ctx.phone,\n    session:  ctx.session,\n    slots:    ctx.slots,\n    patient:  ctx.patient,\n    conv:     ctx.conv,\n    ctx:      ctx.ctx,\n    clinicId: ctx.clinicId\n  }\n}];"
      },
      "id": "f2107bbd-4ddd-40ef-b2c5-a093afee3e6b",
      "name": "Parsear Claude",
      "type": "n8n-nodes-base.code",
