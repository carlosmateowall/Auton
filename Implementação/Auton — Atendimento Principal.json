      "id": "aa000001-0000-0000-0000-000000000009",
      "name": "Notificar Lista de Espera",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 520],
      "notes": "Dispara o workflow Lista de Espera de forma assíncrona (webhook responde imediatamente). neverError=true evita que uma fila vazia quebre o fluxo principal."
    },
    {
      "parameters": {
        "jsCode": "// Sempre referencia Parsear Claude pelo nome — garante que phone, clinicId,\n// conv, ctx etc. estejam presentes independentemente de qual branch\n// (booking, confirmação, cancelamento, fallback) chegou até este nó.\nconst parsed = $('Parsear Claude').item.json;\n\nlet newState   = parsed.conv?.state || 'idle';\nlet newContext = parsed.ctx || {};\n\nif (parsed.action === 'update_state' && parsed.data?.state) {\n  newState   = parsed.data.state;\n  newContext = typeof parsed.data.context === 'object' ? parsed.data.context : {};\n} else if (['book_appointment', 'confirm_appointment', 'cancel_appointment'].includes(parsed.action)) {\n  newState   = 'idle';\n  newContext = {};\n}\n\nconst { randomUUID } = require('crypto');\nconst convId = parsed.conv?.id || randomUUID();\n\nreturn [{ json: { ...parsed, convId, newState, newContext } }];"
      },
