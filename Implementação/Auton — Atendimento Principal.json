      "id": "02d4b587-da3a-4a67-84cd-ca847023e94c",
      "name": "Bloquear Slot",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [304, 100],
      "credentials": {
        "supabaseApi": {
