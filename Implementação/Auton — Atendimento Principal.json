    {
      "parameters": {
        "jsCode": "const parsed  = $('Parsear mensagem').item.json;\nconst convAll = $('Buscar conversa').all();\nconst patAll  = $('Buscar paciente').all();\nconst slotAll = $('Buscar slots').all();\n\nconst conv    = convAll[0]?.json || { state: 'idle', context: '{}', clinic_id: null };\nconst patient = patAll[0]?.json  || null;\nconst slots   = slotAll.map(s => s.json);\n\nreturn [{ json: {\n  phone:    parsed.phone,\n  chatId:   parsed.chatId,\n  text:     parsed.text,\n  session:  parsed.session,\n  conv, patient, slots,\n  clinicId: slots[0]?.clinic_id || conv.clinic_id || 'aaaaaaaa-0000-0000-0000-000000000001'\n} }];"
      },
      "id": "d423fdd6-88af-4303-b31d-a60839f86e14",
      "name": "Montar contexto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1312,
        3984
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst { text, phone, chatId, session, conv, patient, slots, clinicId } = data;\n\nconst state = conv?.state || 'idle';\nlet ctx = {};\ntry { ctx = typeof conv?.context === 'string' ? JSON.parse(conv.context) : (conv?.context || {}); } catch(e) {}\n\nconst input = text.trim().toLowerCase();\nconst num   = parseInt(text.trim());\n\nconst dias = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];\nconst top5 = (slots || []).slice(0, 5);\nconst slotsList = top5.length\n  ? top5.map((s, i) => {\n      const d = new Date(s.date + 'T00:00:00-03:00');\n      return `${i+1}. ${dias[d.getDay()]} ${d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})} as ${s.time.slice(0,5)}`;\n    }).join('\\n')\n  : null;\n\nconst SERVICES = ['Consulta clinica', 'Retorno', 'Exame laboratorial'];\n\nconst MENU_MSG =\n  'Ola! Sou a assistente virtual da Clinica Piloto.\\n\\n' +\n  'Como posso ajudar?\\n\\n' +\n  '1. Agendar consulta\\n' +\n  '2. Cancelar consulta\\n' +\n  '3. Falar com a recepcao\\n\\n' +\n  'Digite o numero da opcao.';\n\nconst SERVICES_MSG =\n  'Qual servico voce precisa?\\n\\n' +\n  '1. Consulta clinica\\n' +\n  '2. Retorno\\n' +\n  '3. Exame laboratorial\\n\\n' +\n  'Digite o numero.';\n\nlet message    = '';\nlet newState   = 'menu';\nlet newContext = {};\nlet action     = 'reply';\nlet bookingData = null;\n\nswitch (state) {\n\n  case 'menu':\n    if (num === 1) {\n      if (!slotsList) {\n        message  = 'Nao ha horarios disponiveis no momento.\\nTente amanha ou ligue para a recepcao.';\n        newState = 'idle';\n      } else {\n        message  = SERVICES_MSG;\n        newState = 'selecting_service';\n      }\n    } else if (num === 2) {\n      message  = 'Para cancelar sua consulta, entre em contato com nossa recepcao.\\nEm breve voce podera cancelar por aqui mesmo!';\n      newState = 'idle';\n    } else if (num === 3) {\n      message  = 'Certo! Nossa recepcionista vai entrar em contato em breve.';\n      newState = 'idle';\n    } else {\n      message  = 'Nao entendi. Por favor, escolha uma opcao:\\n\\n' + MENU_MSG;\n      newState = 'menu';\n    }\n    break;\n\n  case 'selecting_service':\n    if (num >= 1 && num <= 3) {\n      const svc = SERVICES[num - 1];\n      if (!slotsList) {\n        message  = 'Sem horarios disponiveis agora.\\nTente amanha ou ligue para a recepcao.';\n        newState = 'idle';\n      } else {\n        message  = `Otimo! Horarios disponiveis para ${svc}:\\n\\n${slotsList}\\n\\nDigite o numero do horario desejado.`;\n        newState = 'selecting_slot';\n        newContext = { service: svc };\n      }\n    } else {\n      message  = 'Escolha uma opcao valida (1, 2 ou 3):\\n\\n' + SERVICES_MSG;\n      newState = 'selecting_service';\n      newContext = ctx;\n    }\n    break;\n\n  case 'selecting_slot':\n    const svc = ctx.service || 'Consulta clinica';\n    if (num >= 1 && num <= top5.length) {\n      const slot    = top5[num - 1];\n      const d       = new Date(slot.date + 'T00:00:00-03:00');\n      const dateStr = `${dias[d.getDay()]} ${d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})} as ${slot.time.slice(0,5)}`;\n      const patientId = patient?.id || 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n        const r = Math.random() * 16 | 0;\n        return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n      });\n      message  = `Agendamento confirmado!\\n\\nServico: ${svc}\\nData: ${dateStr}\\n\\nAte la! Voce recebera um lembrete no dia anterior.`;\n      newState = 'idle';\n      action   = 'book';\n      bookingData = {\n        slot, slotId: slot.id, service: svc,\n        patientId, patientName: patient?.name || 'Paciente',\n        clinicId: slot.clinic_id || clinicId\n      };\n    } else {\n      message  = `Escolha um numero entre 1 e ${top5.length}:\\n\\n${slotsList}`;\n      newState = 'selecting_slot';\n      newContext = ctx;\n    }\n    break;\n\n  case 'confirming':\n    const isYes = num === 1 || ['sim','s','ok','confirmo','vou'].some(w => input.includes(w));\n    if (isYes) {\n      message = 'Presenca confirmada! Ate amanha.\\n\\nLembre-se: chegue 15 minutos antes.';\n    } else {\n      message = 'Tudo bem! Sua consulta foi cancelada. Quando quiser reagendar, e so chamar.';\n    }\n    newState = 'idle';\n    break;\n\n  case 'idle':\n  default:\n    message  = MENU_MSG;\n    newState = 'menu';\n    break;\n}\n\nconst convId = conv?.id || 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n  const r = Math.random() * 16 | 0;\n  return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n});\n\nreturn [{ json: {\n  message, newState, newContext, action, bookingData,\n  phone, chatId, session, clinicId, convId,\n  conv, patient, slots\n} }];"
      },
